SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
NEXT_PUBLIC_CHAIN=base-sepolia
# Public ERC-4337 bundler RPC for the selected chain.
NEXT_PUBLIC_BUNDLER_URL=
# 1Shot public relayer JSON-RPC endpoints:
#   Testnet: https://relayer.1shotapi.dev/relayers
#   Mainnet: https://relayer.1shotapi.com/relayers
NEXT_PUBLIC_ONESHOT_RELAYER_URL=
# Local demo-only webhook destination for scripts/webhook-listener.ts.
# Production Keycat leaves this empty and polls relayer_getStatus.
NEXT_PUBLIC_ONESHOT_WEBHOOK_URL=
# Public x402-protected AI review endpoint. Must return an ERC-7710 402 challenge.
NEXT_PUBLIC_VENICE_X402_ENDPOINT=
NEXT_PUBLIC_RECOVERY_CONTROLLER_ADDRESS=
NEXT_PUBLIC_WIDGET_URL=https://keycat.net/widget
DEMO_MOCK_RECOVERY=false
